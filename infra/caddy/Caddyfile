*.<apex>, <apex> {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        # CSP for marketing site (and tenant subdomains until tuned per-app).
        # 'unsafe-inline' on script/style covers Astro's inline scripts + Tailwind.
        # Google Fonts: stylesheet from fonts.googleapis.com, woff2 files from
        # fonts.gstatic.com — both must be whitelisted explicitly because
        # `default-src 'self'` would otherwise block them. `connect-src 'self'`
        # pins same-origin for XHR/fetch (htmx).
        Content-Security-Policy "default-src 'self'; img-src 'self' data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self'"
    }

    @marketing host <apex>
    handle @marketing {
        root * /var/www/chalk-marketing/dist
        try_files {path} {path}.html /index.html
        file_server
    }

    handle {
        reverse_proxy 127.0.0.1:8080 {
            health_uri /health
            header_up Host {host}
        }
    }
}
