# DO Managed Postgres (use private network endpoint)
POSTGRES_URL=postgres://chalk:CHANGEME@db-private.internal:25060/chalk?sslmode=require

# 32-byte master key (base64). Generate: openssl rand -base64 32
# CRITICAL: back up to two locations. Loss = re-issue all tenant SAML/OIDC keys.
MASTER_ENCRYPTION_KEY=

# Postmark/SES SMTP token for verification emails
SMTP_TOKEN=

# Cloudflare Turnstile site secret
TURNSTILE_SECRET=

# DigitalOcean API token for Caddy DNS-01 wildcard
DO_AUTH_TOKEN=

# Where /api/marketplace/apply submissions get emailed. Unset = endpoint
# returns 503 and the marketing form falls back to its data-fallback-email
# mailto link.
MARKETPLACE_APPLY_RECIPIENT=
